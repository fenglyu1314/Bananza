# ============================================================
# Unity / 团结引擎 .gitignore
# 基于 https://github.com/github/gitignore/blob/main/Unity.gitignore
# 追加团结引擎 (Tuanjie) 特有目录与常见 IDE/OS 忽略项
# ============================================================

# ---------- Unity 生成目录 ----------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# 团结引擎额外生成目录（按需扩展）
[Aa]rtifacts/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# ---------- IDE / 编辑器 ----------
.vs/
.idea/
.consulo/

# 注意：按用户要求 .vscode/ 纳入仓库，不忽略

# ---------- Visual Studio / Rider 工程文件（Unity 会自动重建） ----------
.vsconfig
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ---------- Unity3D 构建产物 ----------
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app

# ---------- Crashlytics / Firebase ----------
crashlytics-build.properties

# ---------- Packed Addressables ----------
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# ---------- 临时自动生成 ----------
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ---------- 操作系统 ----------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---------- 其他 ----------
*.bak
*.swp
*.orig
